# Job Search Agent — Konfigurationsvorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# API-Keys MÜSSEN in infrastructure/secrets/ abgelegt werden, NICHT hier.

# Backend
APP_ENV=development
LOG_LEVEL=INFO
DB_PATH=./data/jobs.db
CHROMA_PATH=./data/chroma

# Ollama — muss an localhost gebunden sein (keine externe Exposition)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL_STAGE1=mistral-nemo:12b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Standort / Pendelzeit
HOME_ADDRESS=Frankfurt, Germany
MAX_COMMUTE_MIN=60

# Frontend (Vite liest VITE_-Präfix)
VITE_API_BASE_URL=http://localhost:8000
