# Job Search Agent — Konfigurationsvorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# API-Keys MÜSSEN in infrastructure/secrets/ abgelegt werden, NICHT hier.

# ─── Umgebung & Logging ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Datenpersistenz ────────────────────────────────────────────────────────
DB_PATH=./data/jobs.db
CHROMA_PATH=./data/chroma

# ─── Ollama (lokale LLM-Inferenz) ───────────────────────────────────────────
# Ollama muss an localhost gebunden sein (keine externe Exposition)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL_STAGE1=mistral-nemo:12b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Standort & Pendelzeit ──────────────────────────────────────────────────
HOME_ADDRESS=Frankfurt, Germany
MAX_COMMUTE_MIN=60
TRANSIT_DEPARTURE_TIME=08:00
TRANSIT_DEPARTURE_WEEKDAY=tuesday
TRANSIT_CACHE_TTL_DAYS=90

# ─── Scraping-Konfiguration ─────────────────────────────────────────────────
# SCRAPE_KEYWORDS: Leere Liste oder komma-separierte Keywords
# Beispiele: "backend,fullstack" oder "" (leer = alle Jobs scrapen)
SCRAPE_KEYWORDS=

# Suchlocations (komma-separiert, maximal 5)
SCRAPE_LOCATIONS=Frankfurt,Wiesbaden,Darmstadt,Remote

# Suchradius um Home-Adresse in km
SCRAPE_RADIUS_KM=50

# Nur Jobs anzeigen, die in den letzten N Tagen gepostet wurden
SCRAPE_POSTED_WITHIN_DAYS=2

# SCRAPE_EXCLUDE_KEYWORDS: Leere Liste oder komma-separierte Keywords
# Jobs deren Titel diese Keywords enthalten werden ausgefiltert.
# Beispiele: "java,legacy,windows" oder "" (leer = kein Filter)
SCRAPE_EXCLUDE_KEYWORDS=

# ─── Evaluierung (Stage 1 & 2) ──────────────────────────────────────────────
# EVAL_EXCLUDE_KEYWORDS: Zusätzliche Keyword-Liste für Stage-1a Filter
# Jobs deren Titel oder Text diese Keywords enthalten werden sofort ausgefiltert
# (Word-Boundary-Matching, case-insensitive).
# Beispiele: "python,java,c++" oder "" (leer = kein zusätzlicher Filter)
EVAL_EXCLUDE_KEYWORDS=

# Maximale Zeichenanzahl aus Job-Text der an Stage-1b (LLM) übergeben wird
EVAL_STAGE1_RAW_TEXT_LIMIT=1500

# Modell für Stage-2-Evaluierung (detaillierte Bewertung von gefilterten Jobs)
# Empfohlen: claude-haiku-4-5, claude-sonnet-4-20250514
EVAL_STAGE2_MODEL=claude-haiku-4-5

# Batch-Größe für Stage-2-Verarbeitung (wie viele Jobs parallel bewertet werden)
EVAL_STAGE2_BATCH_SIZE=50

# Gewichtung der Score-Dimensionen (muss sich zu 1.0 addieren)
# Einzustellen als JSON-Dict: {"skills": 0.35, "level": 0.25, ...}
# Standard:
#   skills: 0.35     - Relevanz der Fähigkeiten
#   level: 0.25      - Senioritätslevel
#   domain: 0.20     - Industrie/Domain-Match
#   location: 0.15   - Standort-Passung
#   potential: 0.05  - Potenzial für Wachstum
EVAL_STAGE2_WEIGHTS={"skills": 0.35, "level": 0.25, "domain": 0.20, "location": 0.15, "potential": 0.05}

# Verfügbare Evaluierungsstrategien (komma-separiert)
# - structured_core: Standard-Bewertung ohne RAG
# - rag_hybrid: Bewertung mit RAG-Kontextanreicherung
EVAL_STRATEGIES=structured_core,rag_hybrid

# ─── Profil-Extraktion ──────────────────────────────────────────────────────
# Modell für die Extraktion von Kernkompetenzen und Profil aus Job-Text
# Empfohlen: claude-sonnet-4-20250514 (mittel-hoch Komplexität)
PROFILE_EXTRACTION_MODEL=claude-sonnet-4-20250514

# ─── RAG (Retrieval-Augmented Generation) ───────────────────────────────────
# Maximale Tokens pro RAG-Chunk bei der Document-Fragmentierung
RAG_CHUNK_MAX_TOKENS=400

# Anzahl der Top-K ähnlichsten Chunks aus Chroma-Index für RAG
RAG_TOP_K=5

# ─── Frontend (Vite liest VITE_-Präfix) ──────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
